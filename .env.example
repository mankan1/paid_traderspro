# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_64_char_random_hex

# Google Cloud Console → APIs → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_xxx         # or sk_test_xxx for testing
STRIPE_PUBLISHABLE_KEY=pk_live_xxx    # or pk_test_xxx
# Stripe Dashboard → Products → create "$10/month" → copy Price ID
STRIPE_PRICE_ID=price_xxx
# Stripe Dashboard → Developers → Webhooks → add endpoint → copy secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Your Railway URL (no trailing slash)
BASE_URL=https://your-app.up.railway.app

# Restrict to specific emails (leave empty for any Google account)
ALLOWED_EMAILS=you@gmail.com

# How many seconds free users see full dashboard before paywall (default 60)
PREVIEW_SECONDS=60

# SQLite DB path (Railway persistent disk recommended for production)
# DB_PATH=/data/oracle.db
